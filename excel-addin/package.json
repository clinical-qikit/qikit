{
  "name": "qikit-excel-addin",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:no-https": "VITE_NO_MKCERT=true vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:engine": "vitest run --project engine",
    "test:addin": "vitest run --project addin",
    "sideload": "office-addin-debugging start manifest.json",
    "validate": "office-addin-manifest validate manifest.json"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "glob": "^10.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.2.0",
    "vite-plugin-mkcert": "^1.1.7",
    "vitest": "^1.6.0"
  }
}
